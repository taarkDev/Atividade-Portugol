programa {
  funcao inicio(){ 
    inteiro numero
    real pi
    caracter inicial
    logico binario
    cadeia nome

    numero = 20
    pi = 3.14
    inicial = 'm'
    binario = verdadeiro
    nome = "marco"

    escreva(numero, "\n")
    escreva(pi, "\n")
    escreva(inicial, "\n")
    escreva(binario, "\n")
    escreva(nome)
  }
}